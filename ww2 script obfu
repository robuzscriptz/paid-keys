local function removeNpcESP(model)
    local data = npcDrawings[model]
    if data then
        data.box:Remove()
        data.tracer:Remove()
        data.cham:Remove()
        data.nameTag:Remove()
        npcDrawings[model] = nil
        for i, m in ipairs(npcModels) do
            if m == model then
                table.remove(npcModels, i)
                break
            end
        end
    end
end

local function updateESP()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for plr, d in pairs(drawings) do
        if isEnemy(plr) and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    local top = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                    local bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                    local height = bottom.Y - top.Y
                    local width = height / 2
                    local boxPos = Vector2.new(top.X - width/2, top.Y)
                    local boxSize = Vector2.new(width, height)

                    local color = isEnemy(plr) and ENEMY_COLOR or TEAM_COLOR
                    d.box.Color = color
                    d.tracer.Color = color
                    d.cham.Color = color

                    if showCham then
                        d.cham.Size = boxSize + Vector2.new(6, 6)
                        d.cham.Position = boxPos - Vector2.new(3, 3)
                        d.cham.Visible = true
                    else
                        d.cham.Visible = false
                    end

                    d.box.Size = boxSize
                    d.box.Position = boxPos
                    d.box.Visible = espEnabled

                    d.tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    d.tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                    d.tracer.Visible = espEnabled

                    if showNames then
                        local dist = math.round((root.Position - Camera.CFrame.Position).Magnitude)
                        d.nameTag.Text = plr.Name .. "\n" .. dist .. "m"
                        d.nameTag.Position = Vector2.new(top.X, top.Y - 20)
                        d.nameTag.Visible = true
                    else
                        d.nameTag.Visible = false
                    end
                else
                    d.box.Visible = false
                    d.tracer.Visible = false
                    d.cham.Visible = false
                    d.nameTag.Visible = false
                end
            else
                d.box.Visible = false
                d.tracer.Visible = false
                d.cham.Visible = false
                d.nameTag.Visible = false
            end
        else
            d.box.Visible = false
            d.tracer.Visible = false
            d.cham.Visible = false
            d.nameTag.Visible = false
        end
    end

    if showNpcEsp then
        for model, d in pairs(npcDrawings) do
            if isNpcValid(model) then
                local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
                if root then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local top = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
                        local bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                        local height = bottom.Y - top.Y
                        local width = height / 2
                        local boxPos = Vector2.new(top.X - width/2, top.Y)
                        local boxSize = Vector2.new(width, height)

                        if showCham then
                            d.cham.Size = boxSize + Vector2.new(6, 6)
                            d.cham.Position = boxPos - Vector2.new(3, 3)
                            d.cham.Visible = true
                        else
                            d.cham.Visible = false
                        end

                        d.box.Size = boxSize
                        d.box.Position = boxPos
                        d.box.Visible = espEnabled

                        d.tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        d.tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                        d.tracer.Visible = espEnabled

                        if showNames then
                            d.nameTag.Text = "NPC"
                            d.nameTag.Position = Vector2.new(top.X, top.Y - 20)
                            d.nameTag.Visible = true
                        else
                            d.nameTag.Visible = false
                        end
                    else
                        d.box.Visible = false
                        d.tracer.Visible = false
                        d.cham.Visible = false
                        d.nameTag.Visible = false
                    end
                else
                    d.box.Visible = false
                    d.tracer.Visible = false
                    d.cham.Visible = false
                    d.nameTag.Visible = false
                end
            else
                d.box.Visible = false
                d.tracer.Visible = false
                d.cham.Visible = false
                d.nameTag.Visible = false
            end
        end
    else
        for _, d in pairs(npcDrawings) do
            d.box.Visible = false
            d.tracer.Visible = false
            d.cham.Visible = false
            d.nameTag.Visible = false
        end
    end
end

local function getAllTargets()
    local targets = {}
    for _, plr in pairs(Players:GetPlayers()) do
        if isEnemy(plr) and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            local root = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Torso")
            if head and root then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    table.insert(targets, {Player = plr, Head = head, Root = root, isNpc = false})
                end
            end
        end
    end
    for _, model in ipairs(npcModels) do
        if isNpcValid(model) then
            local head = model:FindFirstChild("Head") or model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
            local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
            if head and root then
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    table.insert(targets, {Player = model, Head = head, Root = root, isNpc = true})
                end
            end
        end
    end
    return targets
end

local function getClosestEnemyWithinFOV()
    local closest = nil
    local closestDist = math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, t in pairs(getAllTargets()) do
        local screenPos, onScreen = Camera:WorldToViewportPoint(t.Head.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            if dist < fovRadius and dist < closestDist then
                closestDist = dist
                closest = t
            end
        end
    end
    return closest
end

local function isTargetValid(target)
    if not target then return false end
    if target.isNpc then
        return isNpcValid(target.Player)
    else
        return target.Player and target.Player.Character and target.Player.Character:FindFirstChild("Humanoid") and target.Player.Character.Humanoid.Health > 0
    end
end

local function getTargetPosition(target)
    local char = target.isNpc and target.Player or target.Player.Character
    if not char then return target.Head.Position end
    local part = getBodyPart(char, targetBodyPart)
    if not part then return target.Head.Position end
    local pos = part.Position
    if target.Root then
        local vel = target.Root.AssemblyLinearVelocity
        if vel.Magnitude > 1 then
            local distance = (part.Position - Camera.CFrame.Position).Magnitude
            local factor = math.clamp(distance / PREDICTION_DISTANCE_SCALE, 0, 1)
            local predTime = PREDICTION_TIME * factor
            pos = pos + vel * predTime
        end
    end
    return pos
end

-- ===== MAIN LOOP =====
RunService.RenderStepped:Connect(function()
    updateESP()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    fovCircle.Position = center
    fovCircle.Radius = fovRadius
    fovCircle.Visible = usePOVAimbot

    if not enabled then
        lockedTarget = nil
        return
    end

    local targetToAim = nil

    if usePCAimbot and aiming then
        targetToAim = getClosestEnemyWithinFOV()
        if targetToAim then lockedTarget = nil end
    end

    if usePOVAimbot and not targetToAim then
        if stickyEnabled then
            if lockedTarget and isTargetValid(lockedTarget) then
                local head = lockedTarget.Head
                if head and head.Parent then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                    if onScreen then
                        local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if distToCrosshair > (fovRadius * UNLOCK_THRESHOLD) then
                            lockedTarget = nil
                            local newTarget = getClosestEnemyWithinFOV()
                            if newTarget then
                                lockedTarget = newTarget
                                targetToAim = newTarget
                            end
                        else
                            targetToAim = lockedTarget
                        end
                    else
                        lockedTarget = nil
                    end
                else
                    lockedTarget = nil
                end
            else
                local newTarget = getClosestEnemyWithinFOV()
                if newTarget then
                    lockedTarget = newTarget
                    targetToAim = newTarget
                else
                    lockedTarget = nil
                end
            end
        else
            local newTarget = getClosestEnemyWithinFOV()
            if newTarget then
                targetToAim = newTarget
                lockedTarget = newTarget
            else
                lockedTarget = nil
            end
        end
    end

    if targetToAim then
        local aimPos = getTargetPosition(targetToAim)
        -- Rotate camera only – character body is NOT rotated
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, aimPos)
        if autoShootEnabled then
            mouse1click()
        end
        -- BODY ROTATION REMOVED – character stays natural
    end
end)

-- ===== INPUT =====
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aiming = true
    end
    if input.KeyCode == Enum.KeyCode.Z then
        enabled = not enabled
        if not enabled then lockedTarget = nil end
        print("Master: " .. (enabled and "ON" or "OFF"))
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aiming = false
    end
end)

Players.PlayerRemoving:Connect(function(plr)
    if lockedTarget and not lockedTarget.isNpc and lockedTarget.Player == plr then
        lockedTarget = nil
    end
end)

-- ===== NPC CACHE MANAGEMENT =====
local function scanNpcs()
    for model in pairs(npcDrawings) do
        removeNpcESP(model)
    end
    npcModels = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and isNpcValid(obj) then
            table.insert(npcModels, obj)
            createNpcESP(obj)
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("Model") and isNpcValid(obj) then
        table.insert(npcModels, obj)
        createNpcESP(obj)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("Model") and npcDrawings[obj] then
        removeNpcESP(obj)
    end
end)

for _, plr in pairs(Players:GetPlayers()) do
    createESP(plr)
end
Players.PlayerAdded:Connect(createESP)
scanNpcs()

